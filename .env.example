# Massive market-data API (https://massive.com) — required for `bun run update`.
MASSIVE_API_KEY=

# Optional overrides (defaults shown):
# MASSIVE_BASE_URL=https://api.massive.com
# WIKI_PATH=../stock_wiki     # path to the stock_wiki Obsidian vault
# DAILY_YEARS=2               # years of daily history to request
# FRESH_HOURS=12              # skip symbols refreshed within this many hours
# MASSIVE_RPM=5               # request/min budget (free tier = 5)
